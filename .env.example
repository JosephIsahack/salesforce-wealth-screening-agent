# Salesforce JWT Bearer Flow credentials
SF_USERNAME=your.username@yourorg.com
SF_CONSUMER_KEY=3MVG9...                # OAuth consumer key from your Connected App
SF_PRIVATE_KEY_FILE=server.key          # path to your RSA private key file

# Custom field API names on the Contact object (create these in Salesforce Setup)
SF_WEALTH_SCORE_FIELD=Wealth_Score__c
SF_PROCESSED_FIELD=Wealth_Scan_Processed__c

# 18-character Salesforce User ID to receive high-value Task alerts
SF_ALERT_OWNER_ID=0051a000005XyZAAA0

# Ollama local LLM settings
# Run: brew install ollama && ollama pull gemma4:e4b && ollama serve
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=gemma4:e4b

# FEC API key — optional, defaults to DEMO_KEY (1,000 req/hour shared limit)
# Register for a free key at https://api.data.gov/signup/
FEC_API_KEY=

# How often to poll Salesforce (seconds)
POLL_INTERVAL_SECONDS=300

# Minimum wealth score (0-100) that triggers an alert Task
HIGH_VALUE_THRESHOLD=80
